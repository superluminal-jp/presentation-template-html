# Node / build
node_modules/
# Track the built PPTX + PDF artifacts; ignore everything else in dist/.
# `!dist/` re-includes the dir so the negation below can win over the global ignore of `dist`.
!dist/
dist/*
!dist/sample-deck.pptx
!dist/deck.pdf
build/
*.log

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Playwright
test-results/
playwright-report/

# Env & secrets
.env
.env.*
*.pem
.claude/settings.local.json
